[resource]
script = ExtResource("1_1xhhm")
nome_doador = "Helena"
tipo = 1
pontos = 90
descricao = "A vó fazia macarronada toda sábado na casa dela, a ar ficava carregado do cheiro de macarrão e o som das risadas de toda a família.
Parecia que nada de ruim poderia acontercer enquanto estivessésimos juntos."
resumo_descricao = "Interação social positiva e forte senso de pertencimento familiar. Parece tudo certo."
