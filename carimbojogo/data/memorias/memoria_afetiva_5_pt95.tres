script = ExtResource("1_cfuwk")
nome_doador = "Beatriz"
tipo = 1
pontos = 95
descricao = "Ajudei um idoso a carregar as compras até o carro. Ele ficou muito agredecido pelo minha ajuda. Percebi que a judar os outros me faz bem."
resumo_descricao = "Altruísmo desinteressado e recompensa emocional por boas ações. Ações positivas o outros geram emoções boas em quem as fez, interressante?"
