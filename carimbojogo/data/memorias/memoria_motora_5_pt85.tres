[resource]
script = ExtResource("1_5yqi8")
nome_doador = "Beatriz"
tipo = 2
pontos = 85
doc_inicial = true
resumo_certo = true
descricao = "Eu estava passando outra noite treinando programação. Eu nem olhava mais para as teclas. Meus dedos já sabiam exatamente onde cada letra ficava no teclado.

Parecia que as palavras fluíam da minha mente para a tela do computador. Às vezes eu digitava uma palavra errada, que dava erro em tudo, ficava muito tempo sem perceber onde tava o erro. "
resumo_descricao = "
O controle independente dos dígitos permite a execução de sequências complexas com pouco esforço. Permitindo que o foco seja deslocado para a funções criativas.

Gestão eficente de tarefas, o necessário para um bom desenpenho."
metadata/_custom_type_script = "uid://b5xiaphv2h4ct"
