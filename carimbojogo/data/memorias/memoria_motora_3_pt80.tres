[ext_resource type="Script" uid="uid://b5xiaphv2h4ct" path="res://memorias.gd" id="1_5ir67"]

[resource]
script = ExtResource("1_5ir67")
nome_doador = "Helena"
tipo = 2
pontos = 80
resumo_certo = true
descricao = "Quando você vai cozinhar é muito importante ter cuidado com a faca. Enquando estiver segurando algo para cortar, você deve dobrar as pontas dos dedos pra dentro, mas deixando as unhas meio retas protegendo os dedos. 

Sempre deslizando a faca de corte, sem fazer muita força pra fatiar. \"Facas cegas são perigosas.\".

Foi assim que... me ensinaram há muuuito tempo. Hoje essa técnica é bem natural pra mim."
resumo_descricao = "
Tarefas motoras finas exigem coordenação visual e controle de força. A memória muscular reduz o esforço cognitivo da tarefa."
metadata/_custom_type_script = "uid://b5xiaphv2h4ct"
