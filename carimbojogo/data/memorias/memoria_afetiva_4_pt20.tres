nome_doador = "Miguel "
tipo = 1
pontos = 70
perigo = 0.7
descricao = "Minha mãe me proibiu de ir brincar com meus amigos na rua com medo que eu me machucasse. Fiquei triste, tive que obdecer ela, porque sabe como é né? Mães.2"
resumo_descricao = "Conflito entre desejo pessoal e proteção parental restritiva. Brincar não é uma atividade inerentemente perigosa, todavia a \"mãe\" a proibiu. \"mãe\" não é algo lógico."
