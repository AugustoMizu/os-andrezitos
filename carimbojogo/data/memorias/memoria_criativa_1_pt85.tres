[ext_resource type="Script" uid="uid://b5xiaphv2h4ct" path="res://memorias.gd" id="1_2w17c"]

[resource]
script = ExtResource("1_2w17c")
nome_doador = "Miguel "
tipo = 3
pontos = 85
resumo_certo = true
descricao = "Eu já fiz um curso de pintura quando era adolescente, passava a tarde toda encarando a tela em branco. Sempre começava misturando duas cores escuras, e passando na tela, sem pintar uma forma especifica.

Então ia colocando mais e mais camadas de tinta com tons claros, no final era sempre algo abstrato, meio caótico.

Nem gostava tanto de pintar, mas era uma chance de eu não ficar em casa com meus... com... migo?..."
resumo_descricao = "
O processo de adicionar tinta em uma superfície. A sobreposição de camadas e tons é usada para representar estados emocionais."
metadata/_custom_type_script = "uid://b5xiaphv2h4ct"
