[resource]
script = ExtResource("1_7a51u")
nome_doador = "Arthur"
tipo = 3
pontos = 90
resumo_certo = true
descricao = "Se pudesse eu trabalharia com isso a minha vida inteira. Meu passa tempo preferido é fazer esculturas de argila. É um trabalho braçal, quase uma luta, mas delicado.

Tem que torcer e cavar a argila pra conseguir a forma bruta do que se quer esculpir, então adicionar detalhes, alisar e refinar as bordas aos poucos.

Por que eu não poderia afinal? Né..."
resumo_descricao = "
Manipulações de material maleável. A alteração da forma sob pressão irregular e extrações estratégicas, resultam em forma de arte milenar humana."
metadata/_custom_type_script = "uid://b5xiaphv2h4ct"
