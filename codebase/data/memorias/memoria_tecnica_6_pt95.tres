[resource]
script = ExtResource("1_n3lmk")
nome_doador = "Beatriz"
pontos = 95
doc_inicial = true
resumo_certo = true
descricao = "Digitei um 'Olá, como vai?' na tela e, pela primeira vez, a máquina me respondeu com um 'Olá  Bapo'. Parecia que eu estava conversando com um pessoa feita de peças de computador e código. 

Isso foi logo nos meus primeiros anos da faculdade, antes de eu fazer parte da equipe. Época boa aquela, tirando a parte de fazer provas e acordar cedo todo dia e ter aulas e tal."
resumo_descricao = "
O desenvolvimente de agentes de Inteligencia Artificial exige maquinário e programação adequados, além de conhecimentos especificos ensinados em faculdades.

Interressante."
metadata/_custom_type_script = "uid://b5xiaphv2h4ct"
