script = ExtResource("1_x63f6")
nome_doador = "Maria"
tipo = 3
pontos = 40
doc_inicial = true
descricao = "Já havia se formado um pilha de dezenas de folhas de papel amassadas. A palavra certa não vinha, meu poema parecia muito bobo.

Então usei uma metáfora qualquer que conecte o sentimento de tristeza com a chuva lá fora. Algo como: O céu está nublado, o coração também.\".

Eu deveria escrever com um lápis..."
resumo_descricao = "
O tamanho de uma pilha de papéis está diretamente ligada a criativiade humana. Quanto maior o tamanho da pilha, maior o desempeho do cérebro humano."
metadata/_custom_type_script = "uid://b5xiaphv2h4ct"
